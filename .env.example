# ==============================================================================
# Air Saudia Passenger Portal (ASPP) — Environment Configuration
# ==============================================================================
# Copy this file to .env and fill in the values for your environment.
# NEVER commit the .env file to version control.
# All infrastructure must be KSA-resident to comply with PDPL data residency
# requirements. No PII may be transmitted to non-KSA systems without DPO approval.
# ==============================================================================

# ------------------------------------------------------------------------------
# Application
# ------------------------------------------------------------------------------
PORT=3000
NODE_ENV=development
APP_NAME=Air Saudia Passenger Portal
APP_URL=https://portal.airsaudia.com.sa
API_BASE_URL=https://api.portal.airsaudia.com.sa/v1
FRONTEND_URL=https://portal.airsaudia.com.sa
LOG_LEVEL=info

# ------------------------------------------------------------------------------
# Database — PostgreSQL 15 (KSA-resident)
# ------------------------------------------------------------------------------
DATABASE_URL=postgresql://aspp_user:changeme_db_password@localhost:5432/aspp_db?sslmode=verify-full
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=aspp_db
DATABASE_USER=aspp_user
DATABASE_PASSWORD=changeme_db_password
DATABASE_SSL_MODE=verify-full
DATABASE_SSL_CA_PATH=/etc/ssl/certs/internal-ca.crt
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=20
DATABASE_POOL_IDLE_TIMEOUT_MS=30000

# Read replica (for booking reads, loyalty balance reads)
DATABASE_REPLICA_URL=postgresql://aspp_reader:changeme_reader_password@localhost:5433/aspp_db?sslmode=verify-full

# ------------------------------------------------------------------------------
# Authentication — JWT RS256
# ------------------------------------------------------------------------------
# RS256 signing: private key is stored in KMS; these paths reference local
# PEM files used in development only. In production, signing is performed
# via KMS API — set JWT_USE_KMS=true and configure KMS settings below.
JWT_USE_KMS=false
JWT_PRIVATE_KEY_PATH=/etc/aspp/keys/jwt_private.pem
JWT_PUBLIC_KEY_PATH=/etc/aspp/keys/jwt_public.pem

# Access token lifetime in seconds (15 minutes = 900)
JWT_ACCESS_TOKEN_EXPIRES_IN=900

# Refresh token lifetime in seconds (7 days = 604800)
JWT_REFRESH_TOKEN_EXPIRES_IN=604800

# Pre-auth token lifetime for MFA step in seconds (5 minutes = 300)
JWT_PRE_AUTH_TOKEN_EXPIRES_IN=300

# JWT issuer and audience — must match values validated by JWT Auth Middleware
JWT_ISSUER=https://aspp.airsaudia.com.sa
JWT_AUDIENCE=aspp-api

# JWKS endpoint (public key discovery for service-to-service verification)
JWKS_URI=https://aspp.airsaudia.com.sa/.well-known/jwks.json

# ------------------------------------------------------------------------------
# Authentication — Session & Cookie
# ------------------------------------------------------------------------------
# Session cookie settings (HttpOnly, Secure, SameSite=Strict per architecture)
COOKIE_DOMAIN=.airsaudia.com.sa
COOKIE_SECURE=true
COOKIE_SAME_SITE=Strict
COOKIE_HTTP_ONLY=true

# Session idle timeout in seconds (30 minutes = 1800)
SESSION_IDLE_TIMEOUT_SECONDS=1800

# ------------------------------------------------------------------------------
# Authentication — Account Lockout
# ------------------------------------------------------------------------------
# Number of consecutive failed login attempts before account soft-lock (FR-002)
MAX_FAILED_LOGIN_ATTEMPTS=5

# Duration of account lock in minutes after max failures
ACCOUNT_LOCK_DURATION_MINUTES=15

# Maximum consecutive OTP failures before lock
MAX_FAILED_OTP_ATTEMPTS=5

# ------------------------------------------------------------------------------
# Authentication — Password Policy
# ------------------------------------------------------------------------------
# Bcrypt cost factor for password hashing (cost 12 per LLD)
BCRYPT_COST_FACTOR=12

# Minimum and maximum password length (FR-001)
PASSWORD_MIN_LENGTH=8
PASSWORD_MAX_LENGTH=64

# ------------------------------------------------------------------------------
# Authentication — MFA
# ------------------------------------------------------------------------------
# TOTP window tolerance in steps (1 step = 30 seconds; 1 allows ±30s drift)
TOTP_WINDOW_TOLERANCE=1

# OTP expiry in seconds (10 minutes = 600 per FR-001)
OTP_EXPIRY_SECONDS=600

# OTP delivery timeout SLA in seconds (60 seconds per FR-001)
OTP_DELIVERY_SLA_SECONDS=60

# ------------------------------------------------------------------------------
# Authentication — OAuth2 / PKCE (for future third-party IdP integration)
# ------------------------------------------------------------------------------
OAUTH2_CLIENT_ID=aspp-web
OAUTH2_REDIRECT_URI=https://portal.airsaudia.com.sa/auth/callback
OAUTH2_AUTHORIZATION_CODE_EXPIRY_SECONDS=60

# ------------------------------------------------------------------------------
# Authentication — SAML 2.0 (enterprise/staff SSO)
# ------------------------------------------------------------------------------
SAML_SP_ENTITY_ID=https://aspp.airsaudia.com.sa/saml/metadata
SAML_SP_ACS_URL=https://api.portal.airsaudia.com.sa/v1/saml/acs
SAML_IDP_METADATA_URL=https://idp.airsaudia.com.sa/saml/metadata
SAML_SP_PRIVATE_KEY_PATH=/etc/aspp/keys/saml_sp_private.pem
SAML_SP_CERTIFICATE_PATH=/etc/aspp/keys/saml_sp_cert.pem

# ------------------------------------------------------------------------------
# CORS
# ------------------------------------------------------------------------------
CORS_ALLOWED_ORIGINS=https://portal.airsaudia.com.sa,https://www.airsaudia.com.sa
CORS_ALLOWED_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Content-Type,Authorization,Accept-Language,X-Request-ID
CORS_EXPOSE_HEADERS=X-Request-ID,X-RateLimit-Limit,X-RateLimit-Remaining
CORS_MAX_AGE_SECONDS=86400
CORS_CREDENTIALS=true

# ------------------------------------------------------------------------------
# Rate Limiting
# ------------------------------------------------------------------------------
# Public routes: requests per minute per IP (per HLD Section 2.2)
RATE_LIMIT_PUBLIC_RPM=100

# Authenticated routes: requests per minute per user
RATE_LIMIT_AUTH_RPM=300

# Login endpoint: stricter limit to mitigate brute-force
RATE_LIMIT_LOGIN_RPM=10

# OTP request endpoint
RATE_LIMIT_OTP_RPM=5

# ------------------------------------------------------------------------------
# Redis — Cache, Session, OTP, Rate Limiting, JWT Revocation (KSA-resident)
# ------------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=changeme_redis_password
REDIS_TLS_ENABLED=true
REDIS_TLS_CA_PATH=/etc/ssl/certs/internal-ca.crt
REDIS_DB_INDEX=0

# Redis key prefixes
REDIS_PREFIX_SESSION=aspp:session:
REDIS_PREFIX_OTP=aspp:otp:
REDIS_PREFIX_RATE_LIMIT=aspp:ratelimit:
REDIS_PREFIX_REVOKED_JTI=aspp:revoked_jti:
REDIS_PREFIX_CACHE=aspp:cache:
REDIS_PREFIX_BOOKING_CACHE=aspp:cache:booking:
REDIS_PREFIX_SEAT_CACHE=aspp:cache:seat:
REDIS_PREFIX_MILES_CACHE=aspp:cache:miles:

# Cache TTLs in seconds
REDIS_BOOKING_CACHE_TTL_SECONDS=30
REDIS_SEAT_MAP_CACHE_TTL_SECONDS=10
REDIS_MILES_BALANCE_CACHE_TTL_SECONDS=60

# ------------------------------------------------------------------------------
# Encryption — KMS (KSA-resident HSM-backed KMS)
# ------------------------------------------------------------------------------
# Set KMS_PROVIDER to 'aws' (Bahrain region) or 'stc' (STC Cloud KSA)
KMS_PROVIDER=aws
KMS_REGION=me-south-1
KMS_ENDPOINT=https://kms.me-south-1.amazonaws.com
KMS_KEY_ID_DEK=arn:aws:kms:me-south-1:123456789012:key/aaaaaaaa-bbbb-cccc-dddd-eeeeeeeeeeee
KMS_KEY_ID_JWT=arn:aws:kms:me-south-1:123456789012:key/ffffffff-gggg-hhhh-iiii-jjjjjjjjjjjj
KMS_KEY_ID_LOGGING=arn:aws:kms:me-south-1:123456789012:key/kkkkkkkk-llll-mmmm-nnnn-oooooooooooo
KMS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
KMS_SECRET_ACCESS_KEY=changeme_kms_secret_access_key

# DEK rotation period in days (90 days per architecture)
KMS_DEK_ROTATION_DAYS=90

# ------------------------------------------------------------------------------
# File Storage — S3-Compatible Object Store (KSA-resident, STC Cloud)
# PDPL: All baggage documents stored in KSA only
# ------------------------------------------------------------------------------
S3_ENDPOINT=https://s3.me-south-1.amazonaws.com
S3_REGION=me-south-1
S3_BUCKET_BAGGAGE_DOCS=aspp-baggage-documents-ksa
S3_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE2
S3_SECRET_ACCESS_KEY=changeme_s3_secret_access_key
S3_FORCE_PATH_STYLE=false
S3_SERVER_SIDE_ENCRYPTION=AES256

# Pre-signed URL TTL in seconds (15 minutes = 900 per architecture)
S3_PRESIGNED_URL_TTL_SECONDS=900

# Maximum file upload size in bytes (10 MB = 10485760 per FR-010)
FILE_UPLOAD_MAX_SIZE_BYTES=10485760

# Maximum number of files per baggage claim upload (FR-010)
FILE_UPLOAD_MAX_COUNT=5

# Allowed MIME types for document upload
FILE_UPLOAD_ALLOWED_TYPES=image/jpeg,image/png,application/pdf

# ------------------------------------------------------------------------------
# External APIs — Passenger Service System (PSS) (KSA-resident, Air Saudia DC)
# ------------------------------------------------------------------------------
PSS_BASE_URL=https://pss.internal.airsaudia.com.sa/api/v2
PSS_API_KEY=changeme_pss_api_key
PSS_API_SECRET=changeme_pss_api_secret
PSS_TIMEOUT_MS=8000
PSS_RETRY_ATTEMPTS=3
PSS_RETRY_DELAY_MS=500
PSS_CIRCUIT_BREAKER_THRESHOLD=5
PSS_CIRCUIT_BREAKER_TIMEOUT_MS=30000
PSS_TLS_CA_PATH=/etc/ssl/certs/airsaudia-internal-ca.crt
PSS_TLS_CERT_FINGERPRINT=AA:BB:CC:DD:EE:FF:00:11:22:33:44:55:66:77:88:99:AA:BB:CC:DD:EE:FF:00:11:22:33:44:55:66:77:88:99

# Rebooking cutoff in hours before departure (FR-006: 2 hours)
REBOOKING_CUTOFF_HOURS=2

# Default date range for alternative flight search in days (FR-006: ±3 days)
REBOOKING_SEARCH_DATE_RANGE_DAYS=3

# ------------------------------------------------------------------------------
# External APIs — Loyalty Back-End System (KSA-resident, Air Saudia DC)
# ------------------------------------------------------------------------------
LOYALTY_BASE_URL=https://loyalty.internal.airsaudia.com.sa/api/v1
LOYALTY_API_KEY=changeme_loyalty_api_key
LOYALTY_API_SECRET=changeme_loyalty_api_secret
LOYALTY_TIMEOUT_MS=5000
LOYALTY_RETRY_ATTEMPTS=3
LOYALTY_TLS_CA_PATH=/etc/ssl/certs/airsaudia-internal-ca.crt
LOYALTY_TLS_CERT_FINGERPRINT=11:22:33:44:55:66:77:88:99:AA:BB:CC:DD:EE:FF:00:11:22:33:44:55:66:77:88:99:AA:BB:CC:DD:EE:FF:00

# Miles redemption rules
LOYALTY_MIN_MILES_PER_TRANSACTION=1000
LOYALTY_MILES_INCREMENT=500
LOYALTY_MILES_TO_SAR_RATE=0.01
# 1000 miles = SAR 10 (i.e., 1 mile = SAR 0.01)

# Miles expiry warning threshold in days (FR-013: highlight miles expiring within 90 days)
LOYALTY_EXPIRY_WARNING_DAYS=90

# ------------------------------------------------------------------------------
# External APIs — Baggage Management System (BMS) (KSA-resident, Air Saudia DC)
# ------------------------------------------------------------------------------
BMS_BASE_URL=https://bms.internal.airsaudia.com.sa/api/v1
BMS_API_KEY=changeme_bms_api_key
BMS_API_SECRET=changeme_bms_api_secret
BMS_TIMEOUT_MS=10000
BMS_RETRY_ATTEMPTS=3
BMS_TLS_CA_PATH=/etc/ssl/certs/airsaudia-internal-ca.crt
BMS_TLS_CERT_FINGERPRINT=22:33:44:55:66:77:88:99:AA:BB:CC:DD:EE:FF:00:11:22:33:44:55:66:77:88:99:AA:BB:CC:DD:EE:FF:00:11

# BMS status polling interval in seconds (FR-011: sync within 5 minutes = 300s)
BMS_POLL_INTERVAL_SECONDS=300

# Bag tag number validation pattern (two-letter airline code + 6 digits per FR-010)
BAG_TAG_VALIDATION_PATTERN=^[A-Z]{2}[0-9]{6}$

# ------------------------------------------------------------------------------
# External APIs — Payment Gateway (KSA-hosted, Mada/Visa/Mastercard)
# PDPL: Only tokenised payment references are stored; no raw PAN on ASPP servers
# ------------------------------------------------------------------------------
PAYMENT_GATEWAY_BASE_URL=https://payment.ksa-gateway.com.sa/api/v1
PAYMENT_GATEWAY_MERCHANT_ID=changeme_merchant_id
PAYMENT_GATEWAY_API_KEY=changeme_payment_api_key
PAYMENT_GATEWAY_WEBHOOK_SECRET=changeme_webhook_secret
PAYMENT_GATEWAY_TIMEOUT_MS=10000
PAYMENT_GATEWAY_TLS_CERT_FINGERPRINT=33:44:55:66:77:88:99:AA:BB:CC:DD:EE:FF:00:11:22:33:44:55:66:77:88:99:AA:BB:CC:DD:EE:FF:00:11:22

# Supported payment methods (comma-separated)
PAYMENT_SUPPORTED_METHODS=mada,visa,mastercard

# Currency (all amounts in SAR per BRD)
PAYMENT_CURRENCY=SAR

# Payment processing response timeout SLA in seconds (FR-008: 10 seconds)
PAYMENT_PROCESSING_TIMEOUT_SECONDS=10

# ------------------------------------------------------------------------------
# External APIs — SMS Gateway (KSA telecom provider)
# PDPL: KSA-resident provider; phone numbers and OTPs stay within KSA
# ------------------------------------------------------------------------------
SMS_GATEWAY_BASE_URL=https://sms.ksa-telecom-provider.com.sa/api/v2
SMS_GATEWAY_API_KEY=changeme_sms_api_key
SMS_GATEWAY_API_SECRET=changeme_sms_api_secret
SMS_GATEWAY_SENDER_ID=AirSaudia
SMS_GATEWAY_TIMEOUT_MS=5000
SMS_GATEWAY_RETRY_ATTEMPTS=3

# OTP delivery SLA in seconds (FR-001: within 60 seconds)
SMS_OTP_DELIVERY_SLA_SECONDS=60

# ------------------------------------------------------------------------------
# External APIs — Email Service (KSA-hosted SMTP/API)
# PDPL: KSA-resident email provider; email addresses and PNRs stay within KSA
# ------------------------------------------------------------------------------
EMAIL_PROVIDER=smtp
EMAIL_HOST=smtp.ksa-email-provider.com.sa
EMAIL_PORT=587
EMAIL_SECURE=true
EMAIL_USER=noreply@airsaudia.com.sa
EMAIL_PASSWORD=changeme_email_password
EMAIL_FROM_ADDRESS=noreply@airsaudia.com.sa
EMAIL_FROM_NAME_EN=Air Saudia
EMAIL_FROM_NAME_AR=الخطوط السعودية
EMAIL_TIMEOUT_MS=5000
EMAIL_RETRY_ATTEMPTS=3

# Confirmation email SLA in seconds (FR-009: within 2 minutes = 120s)
EMAIL_CONFIRMATION_SLA_SECONDS=120

# Password reset link validity in seconds (FR-003: 60 minutes = 3600)
PASSWORD_RESET_TOKEN_EXPIRY_SECONDS=3600

# ------------------------------------------------------------------------------
# External APIs — Apple/Google Wallet (non-KSA; DPO approval required)
# PDPL WARNING: These endpoints are outside KSA. DPO approval MUST be recorded
# in identity.cross_border_transfer_approvals before enabling.
# WalletPayloadSanitiser strips all PII not in the approved schema.
# ------------------------------------------------------------------------------
WALLET_ENABLED=false
WALLET_DPO_APPROVAL_ID=
APPLE_WALLET_CERTIFICATE_PATH=/etc/aspp/keys/apple_wallet_cert.pem
APPLE_WALLET_PRIVATE_KEY_PATH=/etc/aspp/keys/apple_wallet_key.pem
APPLE_WALLET_PASS_TYPE_ID=pass.com.airsaudia.boardingpass
APPLE_WALLET_TEAM_ID=CHANGEME_TEAM_ID
GOOGLE_WALLET_ISSUER_ID=changeme_google_wallet_issuer_id
GOOGLE_WALLET_SERVICE_ACCOUNT_KEY_PATH=/etc/aspp/keys/google_wallet_sa.json

# ------------------------------------------------------------------------------
# Notification Service — Bull Queue (Redis-backed)
# ------------------------------------------------------------------------------
QUEUE_REDIS_URL=redis://localhost:6379
QUEUE_CONCURRENCY=5
QUEUE_ATTEMPTS=3
QUEUE_BACKOFF_DELAY_MS=2000

# Claim status notification SLA in seconds (FR-011: within 15 minutes = 900s)
NOTIFICATION_CLAIM_STATUS_SLA_SECONDS=900

# ------------------------------------------------------------------------------
# PDPL Compliance
# ------------------------------------------------------------------------------
# PDPL consent version — must match the version shown to users on registration
PDPL_CONSENT_VERSION=v2.1

# PDPL data subject access request acknowledgement SLA in hours (FR-004: 24h)
PDPL_DSAR_ACKNOWLEDGEMENT_SLA_HOURS=24

# Egress proxy for PDPL cross-border transfer enforcement
PDPL_EGRESS_PROXY_URL=http://egress-proxy.internal.airsaudia.com.sa:3128
PDPL_EGRESS_PROXY_ENABLED=true

# Allowlisted non-KSA endpoints (comma-separated; requires DPO approval per entry)
# Leave empty unless DPO has approved specific cross-border transfers
PDPL_ALLOWED_CROSS_BORDER_ENDPOINTS=

# Logging pseudonymisation HMAC key (used by ELK pipeline to pseudonymise PII fields)
PDPL_LOG_HMAC_KEY=changeme_log_hmac_key_minimum_32_chars

# ------------------------------------------------------------------------------
# Audit Logging
# ------------------------------------------------------------------------------
AUDIT_LOG_RETENTION_DAYS=1095
# 3 years = 1095 days per architecture

# ------------------------------------------------------------------------------
# Observability — APM & Monitoring (KSA-hosted)
# ------------------------------------------------------------------------------
APM_ENABLED=true
APM_SERVICE_NAME=aspp-api
APM_SERVER_URL=https://apm.monitoring.internal.airsaudia.com.sa
APM_SECRET_TOKEN=changeme_apm_secret_token
APM_ENVIRONMENT=production

# Prometheus metrics endpoint
METRICS_ENABLED=true
METRICS_PORT=9090
METRICS_PATH=/metrics

# ------------------------------------------------------------------------------
# Internationalisation (i18n)
# ------------------------------------------------------------------------------
# Default locale when no preference is set
I18N_DEFAULT_LOCALE=ar

# Supported locales (comma-separated)
I18N_SUPPORTED_LOCALES=ar,en

# Locale for Eastern Arabic numerals in Arabic mode (FR-013)
I18N_ARABIC_NUMERAL_LOCALE=ar-SA

# ------------------------------------------------------------------------------
# Seat Selection
# ------------------------------------------------------------------------------
# Seat selection lock-out before departure in hours (FR-018: check-in opens at 48h)
SEAT_SELECTION_CUTOFF_HOURS=48

# Seat map load performance target in seconds (FR-017: ≤ 3 seconds)
SEAT_MAP_LOAD_TARGET_SECONDS=3

# ------------------------------------------------------------------------------
# Check-In & Boarding Pass
# ------------------------------------------------------------------------------
# Check-in window: opens N hours before departure
CHECKIN_OPEN_HOURS_BEFORE_DEPARTURE=48

# Check-in window: closes N hours before departure
CHECKIN_CLOSE_HOURS_BEFORE_DEPARTURE=1

# Boarding pass PDF generation timeout in seconds (NFR-001: ≤ 5 seconds at P99)
BOARDING_PASS_GENERATION_TIMEOUT_SECONDS=5

# ------------------------------------------------------------------------------
# Security Headers
# ------------------------------------------------------------------------------
HSTS_MAX_AGE_SECONDS=31536000
HSTS_INCLUDE_SUBDOMAINS=true
HSTS_PRELOAD=true
CSP_REPORT_URI=https://api.portal.airsaudia.com.sa/v1/csp-report

# ------------------------------------------------------------------------------
# Prisma ORM
# ------------------------------------------------------------------------------
# Prisma uses DATABASE_URL above; these are additional Prisma-specific settings
PRISMA_LOG_LEVEL=warn
# Options: query, info, warn, error